<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="?actionBarSize"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 第一行：操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/button_prev_chapter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@id/exo_rew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/rewind"
                android:src="@drawable/ic_fast_rewind"
                android:tint="?attr/colorOnSurface" />

            <!-- 合并播放/暂停为一个切换按钮，由 PlayerControlView 自动切换图标与行为 -->
            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@id/exo_ffwd"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/fast_forward"
                android:src="@drawable/ic_fast_forward"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/button_next_chapter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="?attr/colorOnSurface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/pages"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_grid" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_options"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/options"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_settings" />
        </LinearLayout>

        <!-- 第二行：进度条 + 时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minEms="5"
                android:gravity="end|center_vertical"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurface"
                android:fontFeatureSettings="tnum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minEms="5"
                android:gravity="start|center_vertical"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurface"
                android:fontFeatureSettings="tnum" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:unplayed_color="?attr/colorOutline"
                app:played_color="?attr/colorPrimary"
                app:buffered_color="?attr/colorOutline"
                app:scrubber_color="?attr/colorPrimary" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>
