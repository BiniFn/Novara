<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="?actionBarSize"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro.VideoControls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <!-- 第一行：进度条 + 时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minEms="5"
                android:gravity="end|center_vertical"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:fontFeatureSettings="tnum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minEms="5"
                android:gravity="start|center_vertical"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:fontFeatureSettings="tnum" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:unplayed_color="#55FFFFFF"
                app:played_color="@android:color/white"
                app:buffered_color="#99FFFFFF"
                app:scrubber_color="@android:color/white" />
        </LinearLayout>

        <!-- 第二行：控制 + 弹幕输入 + 清晰度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:src="@drawable/ic_play"
                android:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/button_prev_chapter"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/button_next_chapter"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/pages"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_grid" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/button_danmaku_toggle"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="2dp"
                android:contentDescription="@string/video_danmaku_enabled"
                android:background="@drawable/bg_danmaku_tv"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="@string/video_danmaku_badge"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/button_danmaku_settings"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="2dp"
                android:contentDescription="@string/video_danmaku_settings"
                android:background="@drawable/bg_danmaku_tv"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingTop="3dp"
                android:text="设"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_danmaku_input"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <ImageButton
                    android:id="@+id/button_danmaku_send"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/video_send_danmaku_hint"
                    android:src="@drawable/ic_send"
                    android:tint="@android:color/white" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edit_danmaku_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/video_send_danmaku_hint"
                    android:imeOptions="actionSend"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textColorHint="#CCFFFFFF" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_rotate_screen"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/rotate_screen"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_screen_rotation" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_quality"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_quality"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_content_video" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>
