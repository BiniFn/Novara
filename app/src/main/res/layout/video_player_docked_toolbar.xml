<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro.VideoControls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- 第一行：进度条 + 时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="end"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:fontFeatureSettings="tnum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:paddingHorizontal="2dp" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="start"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:fontFeatureSettings="tnum" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                app:unplayed_color="#55FFFFFF"
                app:played_color="@android:color/white"
                app:buffered_color="#99FFFFFF"
                app:scrubber_color="@android:color/white" />

        </LinearLayout>

        <!-- 第二行：控制 + 清晰度 -->
        <LinearLayout
            android:id="@+id/controls_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:src="@drawable/ic_play"
                android:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/button_prev_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/button_next_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/pages"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_grid"
                app:iconSize="18dp" />

            <!-- Spacer to push right-side generic buttons -->
            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_rotate_screen"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/rotate_screen"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_screen_rotation"
                app:iconSize="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_quality"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_quality"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_content_video"
                app:iconSize="18dp" />
        </LinearLayout>

        <!-- 第三行：弹幕 + 片头片尾 + 锁屏 -->
        <LinearLayout
            android:id="@+id/controls_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/button_danmaku_toggle"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="@string/video_danmaku_enabled"
                android:background="@drawable/bg_danmaku_tv"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingTop="2dp"
                android:text="@string/video_danmaku_badge"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <ImageButton
                android:id="@+id/button_danmaku_settings"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/video_danmaku_settings"
                android:src="@drawable/ic_danmaku_settings"
                android:scaleType="centerInside"
                android:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:minWidth="60dp"
                android:background="@drawable/bg_danmaku_input"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageButton
                    android:id="@+id/button_danmaku_send"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/video_send_danmaku_hint"
                    android:src="@drawable/ic_send_tilted"
                    android:tint="@android:color/white" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edit_danmaku_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/video_send_danmaku_hint"
                    android:imeOptions="actionSend"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textColorHint="#CCFFFFFF" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/button_mark_intro"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:gravity="center"
                android:text="@string/video_mark_intro"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_danmaku_tv"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/button_mark_outro"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:gravity="center"
                android:text="@string/video_mark_outro"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_danmaku_tv"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <ImageButton
                android:id="@+id/button_screen_lock"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/video_screen_lock"
                android:src="@drawable/ic_lock"
                android:scaleType="centerInside"
                android:tint="@android:color/white" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>
