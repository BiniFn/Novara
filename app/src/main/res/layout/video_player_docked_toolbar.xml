<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="?actionBarSize"
    android:background="?colorSurfaceContainer"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@id/exo_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="?attr/colorOnSurface" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@id/exo_rew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:contentDescription="@string/rewind"
                android:src="@drawable/ic_fast_rewind"
                android:tint="?attr/colorOnSurface" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <!-- 合并播放/暂停为一个切换按钮，由 PlayerControlView 自动切换图标与行为 -->
            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:tint="?attr/colorOnSurface" />
        </FrameLayout>

        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="8dp"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            app:unplayed_color="?attr/colorOutline"
            app:played_color="?attr/colorPrimary"
            app:buffered_color="?attr/colorOutline"
            app:scrubber_color="?attr/colorPrimary" />

        <!-- 当前播放位置文本（由 PlayerControlView 自动绑定） -->
        <TextView
            android:id="@id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical"
            android:minWidth="48dp"
            android:gravity="center_vertical"
            android:textAppearance="?textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface" />

        <!-- 总时长文本（由 PlayerControlView 自动绑定） -->
        <TextView
            android:id="@id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_gravity="center_vertical"
            android:minWidth="48dp"
            android:gravity="center_vertical"
            android:textAppearance="?textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@id/exo_ffwd"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:contentDescription="@string/fast_forward"
                android:src="@drawable/ic_fast_forward"
                android:tint="?attr/colorOnSurface" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@id/exo_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="?attr/colorOnSurface" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="?materialIconButtonStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:contentDescription="@string/pages"
                app:icon="@drawable/ic_grid" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_options"
                style="?materialIconButtonStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:contentDescription="@string/options"
                app:icon="@drawable/ic_settings" />
        </FrameLayout>

    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>