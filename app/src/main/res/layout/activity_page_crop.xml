<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:id="@+id/root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/ucrop_color_crop_background"
	android:fitsSystemWindows="true"
	android:orientation="vertical">

	<RelativeLayout
		android:id="@+id/toolbar_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@color/ucrop_color_toolbar"
		android:minHeight="?attr/actionBarSize"
		android:paddingStart="16dp"
		android:paddingEnd="16dp">

		<TextView
			android:id="@+id/button_cancel"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_centerVertical="true"
			android:layout_alignParentStart="true"
			android:text="@android:string/cancel"
			android:textColor="@color/ucrop_color_toolbar_widget"
			android:textSize="16sp" />

		<TextView
			android:id="@+id/text_title"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_centerInParent="true"
			android:text="@string/crop_pages"
			android:textColor="@color/ucrop_color_toolbar_widget"
			android:textSize="16sp" />

		<TextView
			android:id="@+id/button_save"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_centerVertical="true"
			android:layout_alignParentEnd="true"
			android:text="@string/save"
			android:textColor="@color/ucrop_color_toolbar_widget"
			android:textSize="16sp" />
	</RelativeLayout>

	<com.yalantis.ucrop.view.UCropView
		android:id="@+id/ucrop"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:alpha="0" />

	<LinearLayout
		android:id="@+id/ratio_bar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:minHeight="?attr/actionBarSize"
		android:background="@color/ucrop_color_widget_background"
		android:gravity="center"
		android:padding="8dp">

		<TextView
			android:id="@+id/ratio_original"
			style="@style/ucrop_TextViewCropAspectRatio"
			android:includeFontPadding="false"
			android:gravity="center"
			android:layout_marginEnd="12dp"
			android:text="@string/ucrop_label_original"
			android:textColor="@color/reader_crop_ratio_selector" />

		<TextView
			android:id="@+id/ratio_1_1"
			style="@style/ucrop_TextViewCropAspectRatio"
			android:includeFontPadding="false"
			android:gravity="center"
			android:layout_marginEnd="12dp"
			android:text="1:1"
			android:textColor="@color/reader_crop_ratio_selector" />

		<TextView
			android:id="@+id/ratio_4_3"
			style="@style/ucrop_TextViewCropAspectRatio"
			android:includeFontPadding="false"
			android:gravity="center"
			android:layout_marginEnd="12dp"
			android:text="4:3"
			android:textColor="@color/reader_crop_ratio_selector" />

		<TextView
			android:id="@+id/ratio_16_9"
			style="@style/ucrop_TextViewCropAspectRatio"
			android:includeFontPadding="false"
			android:gravity="center"
			android:text="16:9"
			android:textColor="@color/reader_crop_ratio_selector" />
	</LinearLayout>
</LinearLayout>
