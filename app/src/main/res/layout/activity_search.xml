<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/appbar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:fitsSystemWindows="false"
		app:elevation="0dp"
		app:liftOnScroll="false">

		<com.google.android.material.appbar.MaterialToolbar
			android:id="@id/toolbar"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:layout_scrollFlags="scroll|enterAlways" />

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/layout_query_input"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/list_spacing_normal"
			android:layout_marginEnd="@dimen/list_spacing_normal"
			android:layout_marginBottom="@dimen/list_spacing_small"
			app:layout_scrollFlags="scroll|enterAlways"
			app:startIconDrawable="@android:drawable/ic_menu_search">

			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/edit_query_input"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:singleLine="true"
				android:hint="@string/search"
				android:imeOptions="actionSearch"
				android:inputType="text" />

		</com.google.android.material.textfield.TextInputLayout>

		<LinearLayout
			android:id="@+id/button_advanced_toggle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/list_spacing_normal"
			android:layout_marginEnd="@dimen/list_spacing_normal"
			android:layout_marginBottom="@dimen/list_spacing_small"
			android:orientation="horizontal"
			android:gravity="center_vertical"
			android:clickable="true"
			android:focusable="true"
			android:background="?attr/selectableItemBackground"
			app:layout_scrollFlags="scroll|enterAlways">

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/advanced_search"
				android:textAppearance="?attr/textAppearanceLabelMedium"
				android:textColor="?android:attr/textColorSecondary" />

			<ImageView
				android:id="@+id/icon_advanced_toggle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:src="@drawable/ic_expand_more"
				android:contentDescription="@null" />

		</LinearLayout>

		<LinearLayout
			android:id="@+id/layout_advanced_search"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/list_spacing_normal"
			android:layout_marginEnd="@dimen/list_spacing_normal"
			android:layout_marginBottom="@dimen/list_spacing_small"
			android:orientation="vertical"
			android:visibility="gone"
			app:layout_scrollFlags="scroll|enterAlways"
			tools:visibility="visible">

			<com.google.android.material.textfield.TextInputLayout
				android:id="@+id/layout_advanced_title"
				style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/list_spacing_small"
				android:hint="@string/title">

				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/edit_advanced_title"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:singleLine="true"
					android:imeOptions="actionNext"
					android:inputType="text" />

			</com.google.android.material.textfield.TextInputLayout>

			<com.google.android.material.textfield.TextInputLayout
				android:id="@+id/layout_advanced_tags"
				style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/list_spacing_small"
				android:hint="@string/tags">

				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/edit_advanced_tags"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:singleLine="true"
					android:imeOptions="actionNext"
					android:inputType="text" />

			</com.google.android.material.textfield.TextInputLayout>

			<com.google.android.material.textfield.TextInputLayout
				android:id="@+id/layout_advanced_author"
				style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="@string/author">

				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/edit_advanced_author"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:singleLine="true"
					android:imeOptions="actionSearch"
					android:inputType="text" />

			</com.google.android.material.textfield.TextInputLayout>

		</LinearLayout>

		<TextView
			android:id="@+id/textView_tvbox_repository"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/list_spacing_normal"
			android:layout_marginEnd="@dimen/list_spacing_normal"
			android:layout_marginBottom="@dimen/list_spacing_small"
			android:textAppearance="?attr/textAppearanceLabelMedium"
			android:textColor="?android:attr/textColorSecondary"
			android:visibility="gone"
			app:layout_scrollFlags="scroll|enterAlways"
			tools:text="当前 TVBox 仓库：vip.wwgz.cn:5200"
			tools:visibility="visible" />

	</com.google.android.material.appbar.AppBarLayout>

	<org.skepsun.kototoro.core.ui.list.fastscroll.FastScrollRecyclerView
		android:id="@id/recyclerView"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
		app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
