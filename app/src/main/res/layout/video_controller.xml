<?xml version="1.0" encoding="utf-8"?>
<androidx.media3.ui.PlayerControlView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/exo_controller"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    app:show_timeout="3500">

    <!-- 底侧 DockedToolbar，采用 Material 风格，点击显示后自动隐藏 -->
    <com.google.android.material.dockedtoolbar.DockedToolbarLayout
        android:id="@+id/toolbar_docked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:minHeight="?actionBarSize"
        android:fitsSystemWindows="false"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:theme="@style/ThemeOverlay.Kototoro">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 上一集 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@id/exo_prev"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/prev_chapter"
                    android:src="@drawable/ic_prev"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- 快退 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@id/exo_rew"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/rewind"
                    android:src="@drawable/ic_fast_rewind"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- 播放 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@id/exo_play"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/play"
                    android:src="@drawable/ic_play"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- 暂停 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@id/exo_pause"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/pause"
                    android:src="@drawable/ic_pause"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- 进度条（占据剩余空间） -->
            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="8dp"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                app:unplayed_color="?attr/colorOutline"
                app:played_color="?attr/colorPrimary"
                app:buffered_color="?attr/colorOutline"
                app:scrubber_color="?attr/colorPrimary" />

            <!-- 快进 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@id/exo_ffwd"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/fast_forward"
                    android:src="@drawable/ic_fast_forward"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- 下一集 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@id/exo_next"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/next_chapter"
                    android:src="@drawable/ic_next"
                    android:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- 选集（复用阅读器的按钮样式与尺寸） -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pages_thumbs"
                    style="@style/Widget.Kototoro.IconButton.Transparent"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:contentDescription="@string/pages"
                    app:icon="@drawable/ic_grid" />
            </FrameLayout>

            <!-- 设置（打开视频设置 Sheet） -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_options"
                    style="@style/Widget.Kototoro.IconButton.Transparent"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:contentDescription="@string/options"
                    app:icon="@drawable/ic_settings" />
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.dockedtoolbar.DockedToolbarLayout>

</androidx.media3.ui.PlayerControlView>
