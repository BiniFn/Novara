<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fillViewport="true"
	tools:context=".home.ui.HomeFragment">

	<LinearLayout
		android:id="@+id/homeContentContainer"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingStart="2dp"
		android:paddingTop="4dp"
		android:paddingEnd="2dp"
		android:paddingBottom="24dp">

		<GridLayout
			android:id="@+id/homeCardGrid"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:alignmentMode="alignMargins"
			android:columnCount="2"
			android:rowOrderPreserved="false"
			android:useDefaultMargins="false">

			<!-- 1. Sync Status (Half width) -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_gravity="fill"
				android:layout_margin="1dp"
				android:layout_columnWeight="1"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/sync_status"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<TextView
						android:id="@+id/textViewSyncStatus"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:textAppearance="?attr/textAppearanceBodyMedium"
						tools:text="WebDAV Auto Sync" />

					<TextView
						android:id="@+id/textViewSyncSubtitle"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="4dp"
						android:textAppearance="?attr/textAppearanceBodySmall"
						android:textColor="?android:attr/textColorSecondary"
						tools:text="2 minutes ago" />

					<Space
						android:layout_width="match_parent"
						android:layout_height="0dp"
						android:layout_weight="1" />

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:orientation="vertical">

						<LinearLayout
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="end|center_vertical"
							android:orientation="horizontal">

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonSyncBackup"
								style="?attr/borderlessButtonStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:minWidth="0dp"
								android:insetLeft="0dp"
								android:insetRight="0dp"
								android:paddingHorizontal="8dp"
								android:visibility="gone"
								android:text="@string/create_backup" />

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonSyncRestore"
								style="?attr/borderlessButtonStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:minWidth="0dp"
								android:insetLeft="0dp"
								android:insetRight="0dp"
								android:paddingHorizontal="8dp"
								android:visibility="gone"
								android:text="@string/restore" />
						</LinearLayout>

						<LinearLayout
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="end|center_vertical"
							android:orientation="horizontal">

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonSyncSettings"
								style="?attr/borderlessButtonStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:minWidth="0dp"
								android:insetLeft="0dp"
								android:insetRight="0dp"
								android:paddingHorizontal="8dp"
								android:text="@string/settings" />
						</LinearLayout>
					</LinearLayout>

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<!-- 2. Sources Overview (Half width) -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:layout_gravity="fill"
				android:layout_margin="1dp"
				android:layout_columnWeight="1"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/home_sources_overview"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<TextView
						android:id="@+id/textViewSourceItem1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:textAppearance="?attr/textAppearanceBodySmall"
						tools:text="Built-in · 8" />

					<TextView
						android:id="@+id/textViewSourceItem2"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="4dp"
						android:textAppearance="?attr/textAppearanceBodySmall"
						tools:text="Mihon · 4" />

					<TextView
						android:id="@+id/textViewSourceItem3"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="4dp"
						android:textAppearance="?attr/textAppearanceBodySmall"
						tools:text="TVBox · 3" />

					<Space
						android:layout_width="match_parent"
						android:layout_height="0dp"
						android:layout_weight="1" />

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:gravity="end|center_vertical"
						android:orientation="horizontal">

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonSourceSettings"
							style="?attr/borderlessButtonStyle"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:minWidth="0dp"
							android:insetLeft="0dp"
							android:insetRight="0dp"
							android:paddingHorizontal="8dp"
							android:text="@string/manage" />
					</LinearLayout>

				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- 3. Combined Recent Content (Full width) -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="1dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">



					<!-- History -->
					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:orientation="horizontal">

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/recent_history"
							android:textAppearance="?attr/textAppearanceTitleMedium"
							android:textStyle="bold" />

						<TextView
							android:id="@+id/textViewRecentCount"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginStart="8dp"
							android:text="0"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							android:textColor="?android:attr/textColorSecondary"
							tools:text="5" />

						<Space
							android:layout_width="0dp"
							android:layout_height="match_parent"
							android:layout_weight="1" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonViewAllRecent"
							style="?attr/borderlessButtonStyle"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:minWidth="0dp"
							android:insetLeft="0dp"
							android:insetRight="0dp"
							android:paddingHorizontal="8dp"
							android:text="@string/more" />
					</LinearLayout>

					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/recyclerViewRecentHistory"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:nestedScrollingEnabled="false"
						android:overScrollMode="never"
						tools:listitem="@layout/item_home_cover" />

					<!-- Updates -->
					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:layout_marginTop="8dp"
						android:orientation="horizontal">

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/home_recent_updates"
							android:textAppearance="?attr/textAppearanceTitleMedium"
							android:textStyle="bold" />

						<TextView
							android:id="@+id/textViewUpdatesCount"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginStart="8dp"
							android:text="0"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							android:textColor="?android:attr/textColorSecondary"
							tools:text="3" />

						<Space
							android:layout_width="0dp"
							android:layout_height="match_parent"
							android:layout_weight="1" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonViewAllUpdates"
							style="?attr/borderlessButtonStyle"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:minWidth="0dp"
							android:insetLeft="0dp"
							android:insetRight="0dp"
							android:paddingHorizontal="8dp"
							android:text="@string/more" />
					</LinearLayout>

					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/recyclerViewRecentUpdates"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:nestedScrollingEnabled="false"
						android:overScrollMode="never"
						tools:listitem="@layout/item_home_cover" />

					<!-- Recommendations -->
					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:layout_marginTop="8dp"
						android:orientation="horizontal">

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/suggestions"
							android:textAppearance="?attr/textAppearanceTitleMedium"
							android:textStyle="bold" />

						<TextView
							android:id="@+id/textViewRecommendationsCount"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginStart="8dp"
							android:text="0"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							android:textColor="?android:attr/textColorSecondary"
							tools:text="6" />

						<Space
							android:layout_width="0dp"
							android:layout_height="match_parent"
							android:layout_weight="1" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonViewAllRecommendations"
							style="?attr/borderlessButtonStyle"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:minWidth="0dp"
							android:insetLeft="0dp"
							android:insetRight="0dp"
							android:paddingHorizontal="8dp"
							android:text="@string/more" />
					</LinearLayout>

					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/recyclerViewRecommendations"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:nestedScrollingEnabled="false"
						android:overScrollMode="never"
						tools:listitem="@layout/item_home_cover" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<!-- 4. Quick Access (Full width) -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="1dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/quick_access"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="16dp"
						android:baselineAligned="false"
						android:orientation="horizontal">

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonLibraryOpen"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginEnd="4dp"
							android:text="@string/favourites"
							app:icon="@drawable/ic_heart" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonBookmarks"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginStart="4dp"
							android:text="@string/bookmarks"
							app:icon="@drawable/ic_bookmark" />
					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:baselineAligned="false"
						android:orientation="horizontal">

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonLocal"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginEnd="4dp"
							android:text="@string/local_storage"
							app:icon="@drawable/ic_storage" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonDownloads"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginStart="4dp"
							android:text="@string/downloads"
							app:icon="@drawable/ic_download" />
					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:baselineAligned="false"
						android:orientation="horizontal">

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonRandom"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginEnd="4dp"
							android:text="@string/random"
							app:icon="@drawable/ic_dice" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonAutoTranslate"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginStart="4dp"
							android:text="@string/translation_settings"
							app:icon="@drawable/ic_language" />
					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:baselineAligned="false"
						android:orientation="horizontal">

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonReaderSettings"
							style="?attr/materialButtonOutlinedStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginEnd="4dp"
							android:text="@string/reader_settings"
							app:icon="@drawable/ic_read" />

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonSettings"
							style="?attr/materialButtonStyle"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginStart="4dp"
							android:text="@string/settings"
							app:icon="@drawable/ic_settings" />
					</LinearLayout>

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

		</GridLayout>

	</LinearLayout>

</androidx.core.widget.NestedScrollView>
