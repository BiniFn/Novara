								android:textAppearance="?attr/textAppearanceBodyMedium"
								android:textColor="?android:attr/textColorSecondary"
								tools:text="3" />

						</LinearLayout>

						<com.google.android.material.button.MaterialButtonToggleGroup
							android:id="@+id/toggleGroupUpdatesContentType"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							app:selectionRequired="true"
							app:singleSelection="true">

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonUpdatesFilterManga"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:contentDescription="@string/manga"
								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_manga"
								app:iconPadding="0dp" />

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonUpdatesFilterNovel"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:contentDescription="@string/novel"
								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_novel"
								app:iconPadding="0dp" />

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonUpdatesFilterVideo"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:contentDescription="@string/video"
								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_video"
								app:iconPadding="0dp" />

						</com.google.android.material.button.MaterialButtonToggleGroup>

					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:gravity="center_vertical"
						android:orientation="horizontal">

						<FrameLayout
							android:id="@+id/updateCover1Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="12">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewUpdateItem1Cover"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:contentDescription="@null"
									android:importantForAccessibility="no"
									app:aspectRationHeight="18"
									app:aspectRationWidth="13" />

							</com.google.android.material.card.MaterialCardView>

						</FrameLayout>

						<FrameLayout
							android:id="@+id/updateCover2Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="4">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewUpdateItem2Cover"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:contentDescription="@null"
									android:importantForAccessibility="no"
									app:aspectRationHeight="18"
									app:aspectRationWidth="13" />

							</com.google.android.material.card.MaterialCardView>

						</FrameLayout>

						<FrameLayout
							android:id="@+id/updateCover3Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="8dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="-8">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewUpdateItem3Cover"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:contentDescription="@null"
									android:importantForAccessibility="no"
									app:aspectRationHeight="18"
									app:aspectRationWidth="13" />

							</com.google.android.material.card.MaterialCardView>

						</FrameLayout>

						<com.google.android.material.button.MaterialButton
							android:id="@+id/buttonViewAllUpdates"
