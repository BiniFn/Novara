								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_video"
								app:iconPadding="0dp" />

						</com.google.android.material.button.MaterialButtonToggleGroup>

					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:gravity="center_vertical"
						android:orientation="horizontal">

						<FrameLayout
							android:id="@+id/recommendationCover1Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="12">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewRecommendationItem1Cover"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:contentDescription="@null"
									android:importantForAccessibility="no"
									app:aspectRationHeight="18"
									app:aspectRationWidth="13" />

							</com.google.android.material.card.MaterialCardView>

						</FrameLayout>

						<FrameLayout
							android:id="@+id/recommendationCover2Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="4">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewRecommendationItem2Cover"
