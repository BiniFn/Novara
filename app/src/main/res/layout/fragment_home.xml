<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fillViewport="true"
	tools:context=".home.ui.HomeFragment">

	<LinearLayout
		android:id="@+id/homeContentContainer"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingStart="20dp"
		android:paddingTop="20dp"
		android:paddingEnd="20dp"
		android:paddingBottom="24dp">

		<GridLayout
			android:id="@+id/homeCardGrid"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:alignmentMode="alignMargins"
			android:columnCount="2"
			android:rowOrderPreserved="false"
			android:useDefaultMargins="false">

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:padding="16dp">

					<LinearLayout
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:orientation="vertical">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/sync_status"
							android:textAppearance="?attr/textAppearanceTitleMedium"
							android:textStyle="bold" />

						<TextView
							android:id="@+id/textViewSyncStatus"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="8dp"
							android:textAppearance="?attr/textAppearanceBodyLarge"
							tools:text="WebDAV Auto Sync" />

						<TextView
							android:id="@+id/textViewSyncSubtitle"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							android:textColor="?android:attr/textColorSecondary"
							tools:text="2 minutes ago" />

					</LinearLayout>

					<com.google.android.material.button.MaterialButton
						android:id="@+id/buttonSyncSettings"
						style="?attr/materialButtonOutlinedStyle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="12dp"
						android:text="@string/sync_settings" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:orientation="horizontal">

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/recent_history"
								android:textAppearance="?attr/textAppearanceTitleMedium"
								android:textStyle="bold" />

							<TextView
								android:id="@+id/textViewRecentCount"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="0"
								android:textAppearance="?attr/textAppearanceBodyMedium"
								android:textColor="?android:attr/textColorSecondary"
								tools:text="5" />

						</LinearLayout>

						<com.google.android.material.button.MaterialButtonToggleGroup
							android:id="@+id/toggleGroupRecentContentType"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							app:selectionRequired="true"
							app:singleSelection="true">

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonRecentFilterManga"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:contentDescription="@string/manga"
								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_manga"
								app:iconPadding="0dp" />

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonRecentFilterNovel"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:contentDescription="@string/novel"
								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_novel"
								app:iconPadding="0dp" />

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonRecentFilterVideo"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:contentDescription="@string/video"
								android:insetTop="0dp"
								android:insetBottom="0dp"
								android:minWidth="44dp"
								android:minHeight="44dp"
								app:icon="@drawable/ic_content_video"
								app:iconPadding="0dp" />

						</com.google.android.material.button.MaterialButtonToggleGroup>

					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:gravity="center_vertical"
						android:orientation="horizontal">

						<FrameLayout
							android:id="@+id/recentCover1Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="12">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewRecentItem1Cover"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:contentDescription="@null"
									android:importantForAccessibility="no"
									app:aspectRationHeight="18"
									app:aspectRationWidth="13" />

							</com.google.android.material.card.MaterialCardView>

						</FrameLayout>

						<FrameLayout
							android:id="@+id/recentCover2Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="4">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

								<org.skepsun.kototoro.image.ui.CoverImageView
									android:id="@+id/imageViewRecentItem2Cover"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:contentDescription="@null"
									android:importantForAccessibility="no"
									app:aspectRationHeight="18"
									app:aspectRationWidth="13" />

							</com.google.android.material.card.MaterialCardView>

						</FrameLayout>

						<FrameLayout
							android:id="@+id/recentCover3Container"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginEnd="8dp"
							android:layout_weight="1"
							android:clickable="true"
							android:clipChildren="false"
							android:clipToPadding="false"
							android:focusable="true"
							android:foreground="?attr/selectableItemBackgroundBorderless"
							android:rotationY="-8">

							<com.google.android.material.card.MaterialCardView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								app:cardUseCompatPadding="true">

