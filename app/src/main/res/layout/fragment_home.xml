<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fillViewport="true"
	tools:context=".home.ui.HomeFragment">

	<LinearLayout
		android:id="@+id/homeContentContainer"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingStart="20dp"
		android:paddingTop="20dp"
		android:paddingEnd="20dp"
		android:paddingBottom="24dp">

		<com.google.android.material.chip.ChipGroup
			android:id="@+id/chipGroupHomeContentType"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:chipSpacingHorizontal="8dp"
			app:chipSpacingVertical="8dp"
			app:singleLine="false"
			app:singleSelection="true"
			app:selectionRequired="true">

			<com.google.android.material.chip.Chip
				android:id="@+id/chipHomeManga"
				style="@style/Widget.Material3.Chip.Filter"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/manga"
				app:chipIcon="@drawable/ic_content_manga"
				app:chipIconVisible="true" />

			<com.google.android.material.chip.Chip
				android:id="@+id/chipHomeNovel"
				style="@style/Widget.Material3.Chip.Filter"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/novel"
				app:chipIcon="@drawable/ic_content_novel"
				app:chipIconVisible="true" />

			<com.google.android.material.chip.Chip
				android:id="@+id/chipHomeVideo"
				style="@style/Widget.Material3.Chip.Filter"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/video"
				app:chipIcon="@drawable/ic_content_video"
				app:chipIconVisible="true" />

		</com.google.android.material.chip.ChipGroup>

		<GridLayout
			android:id="@+id/homeCardGrid"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:alignmentMode="alignMargins"
			android:columnCount="2"
			android:rowOrderPreserved="false"
			android:useDefaultMargins="false">

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/home_overview_title"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="16dp"
						android:orientation="horizontal">

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/recent_history"
								android:textAppearance="?attr/textAppearanceLabelMedium"
								android:textColor="?android:attr/textColorSecondary" />

							<TextView
								android:id="@+id/textViewRecentCount"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="0"
								android:textAppearance="?attr/textAppearanceHeadlineSmall"
								android:textStyle="bold"
								tools:text="5" />

						</LinearLayout>

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/unread_updates"
								android:textAppearance="?attr/textAppearanceLabelMedium"
								android:textColor="?android:attr/textColorSecondary" />

							<TextView
								android:id="@+id/textViewUpdatesCount"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="0"
								android:textAppearance="?attr/textAppearanceHeadlineSmall"
								android:textStyle="bold"
								tools:text="3" />

						</LinearLayout>

					</LinearLayout>

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="16dp"
						android:orientation="horizontal">

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/preferred_tracking_site"
								android:textAppearance="?attr/textAppearanceLabelMedium"
								android:textColor="?android:attr/textColorSecondary" />

							<TextView
								android:id="@+id/textViewTrackingSite"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:textAppearance="?attr/textAppearanceTitleMedium"
								android:textStyle="bold"
								tools:text="BANGUMI" />

						</LinearLayout>

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/sync_status"
								android:textAppearance="?attr/textAppearanceLabelMedium"
								android:textColor="?android:attr/textColorSecondary" />

							<TextView
								android:id="@+id/textViewOverviewSyncStatus"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:textAppearance="?attr/textAppearanceTitleMedium"
								android:textStyle="bold"
								tools:text="WebDAV Auto Sync" />

						</LinearLayout>

					</LinearLayout>

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:padding="16dp">

					<org.skepsun.kototoro.image.ui.CoverImageView
						android:id="@+id/imageViewResumeCover"
						android:layout_width="96dp"
						android:layout_height="wrap_content"
						android:contentDescription="@null"
						android:importantForAccessibility="no"
						app:aspectRationHeight="18"
						app:aspectRationWidth="13"
						tools:ignore="ImageContrastCheck" />

					<LinearLayout
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_marginStart="16dp"
						android:layout_weight="1"
						android:orientation="vertical">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/home_resume_title"
							android:textAppearance="?attr/textAppearanceTitleMedium"
							android:textStyle="bold" />

						<TextView
							android:id="@+id/textViewResumeTitle"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="12dp"
							android:ellipsize="end"
							android:maxLines="2"
							android:textAppearance="?attr/textAppearanceBodyLarge"
							android:textStyle="bold"
							tools:text="Last read content title" />

						<TextView
							android:id="@+id/textViewResumeSubtitle"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							android:textColor="?android:attr/textColorSecondary"
							tools:text="Progress 42%" />

						<LinearLayout
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="12dp"
							android:orientation="horizontal">

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonResumeRead"
								style="?attr/materialButtonStyle"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:layout_weight="1"
								android:text="@string/read" />

							<com.google.android.material.button.MaterialButton
								android:id="@+id/buttonResumeDetails"
								style="?attr/materialButtonOutlinedStyle"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:layout_marginStart="12dp"
								android:layout_weight="1"
								android:text="@string/details" />

						</LinearLayout>

					</LinearLayout>

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:padding="16dp">

					<LinearLayout
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:orientation="vertical">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/sync_status"
							android:textAppearance="?attr/textAppearanceTitleMedium"
							android:textStyle="bold" />

						<TextView
							android:id="@+id/textViewSyncStatus"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="8dp"
							android:textAppearance="?attr/textAppearanceBodyLarge"
							tools:text="WebDAV Auto Sync" />

						<TextView
							android:id="@+id/textViewSyncSubtitle"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							android:textColor="?android:attr/textColorSecondary"
							tools:text="2 minutes ago" />

					</LinearLayout>

					<com.google.android.material.button.MaterialButton
						android:id="@+id/buttonSyncSettings"
						style="?attr/materialButtonOutlinedStyle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="12dp"
						android:text="@string/sync_settings" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/recent_history"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<LinearLayout
						android:id="@+id/recentItem1Container"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:background="?attr/selectableItemBackground"
						android:clickable="true"
						android:focusable="true"
						android:gravity="center_vertical"
						android:minHeight="64dp"
						android:orientation="horizontal"
						android:padding="8dp">

						<org.skepsun.kototoro.image.ui.CoverImageView
							android:id="@+id/imageViewRecentItem1Cover"
							android:layout_width="44dp"
							android:layout_height="wrap_content"
							android:contentDescription="@null"
							android:importantForAccessibility="no"
							app:aspectRationHeight="18"
							app:aspectRationWidth="13" />

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginStart="12dp"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:id="@+id/textViewRecentItem1"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:ellipsize="end"
								android:maxLines="1"
								android:textAppearance="?attr/textAppearanceBodyMedium"
								android:textStyle="bold"
								tools:text="Recent title 1" />

							<TextView
								android:id="@+id/textViewRecentItem1Meta"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="2dp"
								android:textAppearance="?attr/textAppearanceBodySmall"
								android:textColor="?android:attr/textColorSecondary"
								tools:text="Open details" />

						</LinearLayout>

					</LinearLayout>

					<LinearLayout
						android:id="@+id/recentItem2Container"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:background="?attr/selectableItemBackground"
						android:clickable="true"
						android:focusable="true"
						android:gravity="center_vertical"
						android:minHeight="64dp"
						android:orientation="horizontal"
						android:padding="8dp">

						<org.skepsun.kototoro.image.ui.CoverImageView
							android:id="@+id/imageViewRecentItem2Cover"
							android:layout_width="44dp"
							android:layout_height="wrap_content"
							android:contentDescription="@null"
							android:importantForAccessibility="no"
							app:aspectRationHeight="18"
							app:aspectRationWidth="13" />

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginStart="12dp"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:id="@+id/textViewRecentItem2"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:ellipsize="end"
								android:maxLines="1"
								android:textAppearance="?attr/textAppearanceBodyMedium"
								android:textStyle="bold"
								tools:text="Recent title 2" />

							<TextView
								android:id="@+id/textViewRecentItem2Meta"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="2dp"
								android:textAppearance="?attr/textAppearanceBodySmall"
								android:textColor="?android:attr/textColorSecondary"
								tools:text="Open details" />

						</LinearLayout>

					</LinearLayout>

					<LinearLayout
						android:id="@+id/recentItem3Container"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:background="?attr/selectableItemBackground"
						android:clickable="true"
						android:focusable="true"
						android:gravity="center_vertical"
						android:minHeight="64dp"
						android:orientation="horizontal"
						android:padding="8dp">

						<org.skepsun.kototoro.image.ui.CoverImageView
							android:id="@+id/imageViewRecentItem3Cover"
							android:layout_width="44dp"
							android:layout_height="wrap_content"
							android:contentDescription="@null"
							android:importantForAccessibility="no"
							app:aspectRationHeight="18"
							app:aspectRationWidth="13" />

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_marginStart="12dp"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:id="@+id/textViewRecentItem3"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:ellipsize="end"
								android:maxLines="1"
								android:textAppearance="?attr/textAppearanceBodyMedium"
								android:textStyle="bold"
								tools:text="Recent title 3" />

							<TextView
								android:id="@+id/textViewRecentItem3Meta"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="2dp"
								android:textAppearance="?attr/textAppearanceBodySmall"
								android:textColor="?android:attr/textColorSecondary"
								tools:text="Open details" />

						</LinearLayout>

					</LinearLayout>

					<com.google.android.material.button.MaterialButton
						android:id="@+id/buttonViewAllRecent"
						style="?attr/materialButtonOutlinedStyle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:text="@string/view_all" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="1"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/home_library_overview"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="16dp"
						android:orientation="horizontal">

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/favorite_count"
								android:textAppearance="?attr/textAppearanceLabelMedium"
								android:textColor="?android:attr/textColorSecondary" />

							<TextView
								android:id="@+id/textViewLibraryFavoritesCount"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="0"
								android:textAppearance="?attr/textAppearanceHeadlineSmall"
								android:textStyle="bold"
								tools:text="12" />

						</LinearLayout>

						<LinearLayout
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:orientation="vertical">

							<TextView
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:text="@string/categories"
								android:textAppearance="?attr/textAppearanceLabelMedium"
								android:textColor="?android:attr/textColorSecondary" />

							<TextView
								android:id="@+id/textViewLibraryCategoriesCount"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="0"
								android:textAppearance="?attr/textAppearanceHeadlineSmall"
								android:textStyle="bold"
								tools:text="4" />

						</LinearLayout>

					</LinearLayout>

					<com.google.android.material.button.MaterialButton
						android:id="@+id/buttonLibraryOpen"
						style="?attr/materialButtonOutlinedStyle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:text="@string/favourites" />

				</LinearLayout>

			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_columnSpan="2"
				android:layout_gravity="fill_horizontal"
				android:layout_margin="4dp"
				android:layout_columnWeight="2"
				app:cardUseCompatPadding="true">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:padding="16dp">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/home_recent_updates"
						android:textAppearance="?attr/textAppearanceTitleMedium"
						android:textStyle="bold" />

					<TextView
						android:id="@+id/textViewUpdateItem1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:background="?attr/selectableItemBackground"
						android:clickable="true"
						android:ellipsize="end"
						android:focusable="true"
						android:maxLines="1"
						android:padding="8dp"
						android:textAppearance="?attr/textAppearanceBodyMedium"
						tools:text="Updated title 1" />

					<TextView
						android:id="@+id/textViewUpdateItem1Meta"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="8dp"
						android:layout_marginTop="2dp"
						android:textAppearance="?attr/textAppearanceBodySmall"
						android:textColor="?android:attr/textColorSecondary"
						tools:text="+2 chapters" />

					<TextView
						android:id="@+id/textViewUpdateItem2"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:background="?attr/selectableItemBackground"
						android:clickable="true"
						android:ellipsize="end"
						android:focusable="true"
						android:maxLines="1"
						android:padding="8dp"
						android:textAppearance="?attr/textAppearanceBodyMedium"
						tools:text="Updated title 2" />

					<TextView
						android:id="@+id/textViewUpdateItem2Meta"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="8dp"
						android:layout_marginTop="2dp"
						android:textAppearance="?attr/textAppearanceBodySmall"
						android:textColor="?android:attr/textColorSecondary"
						tools:text="+1 chapter" />

					<TextView
						android:id="@+id/textViewUpdateItem3"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:background="?attr/selectableItemBackground"
						android:clickable="true"
						android:ellipsize="end"
						android:focusable="true"
						android:maxLines="1"
						android:padding="8dp"
						android:textAppearance="?attr/textAppearanceBodyMedium"
						tools:text="Updated title 3" />

					<TextView
						android:id="@+id/textViewUpdateItem3Meta"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginStart="8dp"
