<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/cardLayout"
	android:layout_width="@dimen/small_grid_width"
	android:layout_height="wrap_content"
	android:layout_marginEnd="2dp"
	android:clickable="true"
	android:focusable="true"
	android:foreground="?attr/selectableItemBackgroundBorderless"
	android:orientation="vertical"
	tools:layout_width="@dimen/small_grid_width">

	<com.google.android.material.card.MaterialCardView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:cardElevation="2dp"
		app:cardUseCompatPadding="true"
		app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Kototoro.Cover">

		<org.skepsun.kototoro.image.ui.CoverImageView
			android:id="@+id/imageViewCover"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:contentDescription="@null"
			android:importantForAccessibility="no"
			app:aspectRationHeight="18"
			app:aspectRationWidth="13"
			tools:src="@tools:sample/backgrounds/scenic" />

	</com.google.android.material.card.MaterialCardView>

	<TextView
		android:id="@+id/textViewTitle"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:elegantTextHeight="false"
		android:ellipsize="end"
		android:lines="2"
		android:paddingHorizontal="4dp"
		android:paddingBottom="4dp"
		android:textAppearance="?attr/textAppearanceTitleSmall"
		android:textColor="?android:attr/textColorPrimary"
		tools:text="This is a very long text example for manga title" />

</LinearLayout>
