<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <org.skepsun.kototoro.core.ui.sheet.AdaptiveSheetHeaderBar
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/video_super_resolution_advanced" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:scrollIndicators="top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/margin_normal">

            <com.google.android.material.card.MaterialCardView
                style="?materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_normal"
                android:layout_marginEnd="@dimen/margin_normal"
                android:layout_marginTop="@dimen/margin_normal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/margin_normal"
                    android:paddingEnd="@dimen/margin_normal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_mode_a"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_a" />

                    <TextView
                        android:id="@+id/text_mode_a_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/video_super_resolution_mode_a_desc"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_mode_b"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_b" />

                    <TextView
                        android:id="@+id/text_mode_b_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/video_super_resolution_mode_b_desc"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_mode_c"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_c" />

                    <TextView
                        android:id="@+id/text_mode_c_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/video_super_resolution_mode_c_desc"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_mode_aa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_aa" />

                    <TextView
                        android:id="@+id/text_mode_aa_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/video_super_resolution_mode_aa_desc"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_mode_bb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_bb" />

                    <TextView
                        android:id="@+id/text_mode_bb_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/video_super_resolution_mode_bb_desc"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_mode_ca"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_ca" />

                    <TextView
                        android:id="@+id/text_mode_ca_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_mode_ca_desc"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</LinearLayout>
