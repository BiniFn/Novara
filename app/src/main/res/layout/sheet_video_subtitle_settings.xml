<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainerHigh">

    <org.skepsun.kototoro.core.ui.sheet.AdaptiveSheetHeaderBar
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/video_subtitle_settings" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:isScrollContainer="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <!-- Typography Container -->
            <LinearLayout
                android:id="@+id/container_typography"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/video_subtitle_style"
                    android:textAppearance="?textAppearanceLabelLarge"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/group_style_format"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:singleSelection="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bold"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="B"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_italic"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="I"
                        android:textStyle="italic" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/group_style_align"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_align_left"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Left" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_align_center"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Center" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_align_right"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Right" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:id="@+id/tv_font_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/video_subtitle_font_size"
                    android:textAppearance="?textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_font_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:value="16"
                    android:valueFrom="10"
                    android:valueTo="100"
                    android:stepSize="1" />

                <TextView
                    android:id="@+id/tv_border_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/video_subtitle_border_size"
                    android:textAppearance="?textAppearanceBodyMedium"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_border_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="24"
                    android:stepSize="1" />
            </LinearLayout>

            <!-- Layout Container -->
            <LinearLayout
                android:id="@+id/container_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/video_subtitle_position"
                    android:textAppearance="?textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_position"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="300"
                    android:stepSize="1" />
            </LinearLayout>

            <!-- Colors Container -->
            <LinearLayout
                android:id="@+id/container_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/group_color_target"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_color_text"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/video_subtitle_color_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_color_border"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/video_subtitle_color_border" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_color_bg"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/video_subtitle_color_bg" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:id="@+id/tv_color_a"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alpha"
                    android:textAppearance="?textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_color_a"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="255"
                    android:stepSize="1" />

                <TextView
                    android:id="@+id/tv_color_r"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Red"
                    android:textAppearance="?textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_color_r"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="255"
                    android:stepSize="1"
                    app:thumbColor="#FF0000"
                    app:trackColorActive="#FF0000" />

                <TextView
                    android:id="@+id/tv_color_g"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Green"
                    android:textAppearance="?textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_color_g"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="255"
                    android:stepSize="1"
                    app:thumbColor="#00FF00"
                    app:trackColorActive="#00FF00" />

                <TextView
                    android:id="@+id/tv_color_b"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blue"
                    android:textAppearance="?textAppearanceBodyMedium" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_color_b"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="255"
                    android:stepSize="1"
                    app:thumbColor="#0000FF"
                    app:trackColorActive="#0000FF" />

            </LinearLayout>

        </FrameLayout>
    </ScrollView>
</LinearLayout>
