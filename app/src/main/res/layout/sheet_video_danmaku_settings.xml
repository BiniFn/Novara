<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <org.skepsun.kototoro.core.ui.sheet.AdaptiveSheetHeaderBar
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/video_danmaku_settings" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:scrollIndicators="top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/margin_normal">

            <com.google.android.material.card.MaterialCardView
                style="?materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_normal"
                android:layout_marginEnd="@dimen/margin_normal"
                android:layout_marginTop="@dimen/margin_normal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/margin_normal"
                    android:paddingEnd="@dimen/margin_normal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/text_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_size"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="50"
                        android:valueTo="150"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/text_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_speed"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/text_opacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_opacity"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_opacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="10"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/text_stroke"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_stroke"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_stroke"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/text_max_screen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_max_screen"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_max_screen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="?attr/colorOutline" />

                    <TextView
                        android:id="@+id/text_sources"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_sources"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_source_dandan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_source_dandan" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_source_bilibili"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_source_bilibili" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_source_qq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_source_qq" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_scroll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_show_scroll" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_top"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_show_top" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_bottom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_danmaku_show_bottom" />

                    <TextView
                        android:id="@+id/text_max_scroll_lines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_max_scroll_lines"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_max_scroll_lines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="20"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/text_max_top_lines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_max_top_lines"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_max_top_lines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="10"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/text_max_bottom_lines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/video_danmaku_max_bottom_lines"
                        android:textAppearance="?textAppearanceBodyMedium" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_max_bottom_lines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="10"
                        android:stepSize="1" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</LinearLayout>
