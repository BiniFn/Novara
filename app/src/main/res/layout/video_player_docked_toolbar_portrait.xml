<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro.VideoControls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- 第一行：进度条 + 时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="end"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurface"
                android:fontFeatureSettings="tnum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingHorizontal="2dp" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="start"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurface"
                android:fontFeatureSettings="tnum" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                app:unplayed_color="?attr/colorOutline"
                app:played_color="?attr/colorPrimary"
                app:buffered_color="?attr/colorOutline"
                app:scrubber_color="?attr/colorPrimary" />

        </LinearLayout>

        <!-- 第二行：控制 + 弹幕输入 + 清晰度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:src="@drawable/ic_play"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/button_prev_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/button_next_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="?attr/colorOnSurface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/pages"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_grid"
                app:iconSize="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_danmaku_settings"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_danmaku_settings"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_interaction_large"
                app:iconSize="18dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#66FFFFFF"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="?attr/colorOnSurfaceVariant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_danmaku_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/video_send_danmaku_hint"
                    android:imeOptions="actionSend"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_danmaku_send"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_send_danmaku_hint"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconSize="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_rotate_screen"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/rotate_screen"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_screen_rotation"
                app:iconSize="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_quality"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_quality"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_content_video"
                app:iconSize="18dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>
