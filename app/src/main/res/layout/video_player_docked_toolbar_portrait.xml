<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 第一行：播放控制 + 进度条 + 时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:tint="?attr/colorOnSurface" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                app:unplayed_color="?attr/colorOutline"
                app:played_color="?attr/colorPrimary"
                app:buffered_color="?attr/colorOutline"
                app:scrubber_color="?attr/colorPrimary" />

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="end"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurface"
                android:fontFeatureSettings="tnum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingHorizontal="2dp" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="start"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurface"
                android:fontFeatureSettings="tnum" />

        </LinearLayout>

        <!-- 第二行：上一集 + 快退 + 快进 + 下一集 + 章节 + 设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/button_prev_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@id/exo_rew"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/rewind"
                android:src="@drawable/ic_fast_rewind"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@id/exo_ffwd"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/fast_forward"
                android:src="@drawable/ic_fast_forward"
                android:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/button_next_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="?attr/colorOnSurface" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/pages"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_grid"
                app:iconSize="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_options"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/options"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_settings"
                app:iconSize="18dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>
