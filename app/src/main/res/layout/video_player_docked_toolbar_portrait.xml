<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.dockedtoolbar.DockedToolbarLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_docked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:theme="@style/ThemeOverlay.Kototoro.VideoControls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- 绗竴琛岋細杩涘害鏉?+ 鏃堕棿 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/play"
                android:src="@drawable/ic_play"
                android:tint="@android:color/white" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:unplayed_color="#55FFFFFF"
                app:played_color="@android:color/white"
                app:buffered_color="#99FFFFFF"
                app:scrubber_color="@android:color/white" />

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="end"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:fontFeatureSettings="tnum" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:paddingHorizontal="2dp" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="50dp"
                android:minEms="4"
                android:gravity="start"
                android:textAppearance="?textAppearanceBodySmall"
                android:textColor="@android:color/white"
                android:fontFeatureSettings="tnum" />

        </LinearLayout>

        <!-- 绗簩琛岋細鎺у埗 + 娓呮櫚搴?-->
        <LinearLayout
            android:id="@+id/controls_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/button_prev_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/prev_chapter"
                android:src="@drawable/ic_prev"
                android:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/button_next_chapter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/next_chapter"
                android:src="@drawable/ic_next"
                android:tint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pages_thumbs"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/pages"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_grid"
                app:iconSize="18dp" />

            <!-- Spacer to push right-side generic buttons -->
            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_mark_intro"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/video_mark_intro"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_mark_outro"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/video_mark_outro"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_quality"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_quality"
                android:text="@string/video_quality"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_screen_lock"
                style="@style/Widget.Kototoro.IconButton.Transparent"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/video_screen_lock"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:icon="@drawable/ic_lock"
                app:iconSize="18dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.dockedtoolbar.DockedToolbarLayout>
