<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:clipToPadding="false">

    <org.skepsun.kototoro.video.player.CustomMpvView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <com.bytedance.danmaku.render.engine.DanmakuView
        android:id="@+id/danmaku_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:importantForAccessibility="no" />

    <View
        android:id="@+id/top_gradient"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_video_top_gradient"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <View
        android:id="@+id/bottom_gradient"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_video_bottom_gradient"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <!-- 顶部状态栏区域的遮罩（scrim），用于在显示工具栏时让状态栏不透明且与工具栏颜色一致 -->
    <View
        android:id="@+id/status_bar_scrim"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="?attr/colorSurfaceContainerHigh"
        android:visibility="gone"
        android:elevation="4dp"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:elevation="8dp">
        
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            app:contentInsetStart="8dp"
            app:contentInsetEnd="8dp"
            app:contentInsetStartWithNavigation="8dp"
            app:theme="@style/ThemeOverlay.Kototoro.VideoControls"
            app:layout_scrollFlags="scroll|enterAlways"
            app:popupTheme="@style/ThemeOverlay.Kototoro"
            app:titleTextAppearance="?textAppearanceTitleSmall"
            app:titleTextColor="?attr/colorOnSurface"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant">

            <!-- 顶部工具栏内的短进度条，用于显示播放进度 -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/toolbar_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:visibility="gone"
                android:indeterminate="false"
                app:trackThickness="4dp"
                app:indicatorColor="?attr/colorPrimary"
                app:trackColor="?attr/colorOutline" />
        </com.google.android.material.appbar.MaterialToolbar>

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_secondary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            app:contentInsetStart="8dp"
            app:contentInsetEnd="8dp"
            app:theme="@style/ThemeOverlay.Kototoro.VideoControls"
            app:popupTheme="@style/ThemeOverlay.Kototoro" />
            
    </LinearLayout>

    <!-- 外层 PlayerControlView 包裹 DockedToolbar，使播放控件自动绑定到 ExoPlayer -->
    <!-- 横屏布局 -->
    <androidx.media3.ui.PlayerControlView
        android:id="@+id/controller"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:visibility="gone"
        app:show_timeout="0"
        app:controller_layout_id="@layout/video_player_docked_toolbar" />

    <!-- 左右双击/长按手势提示浮层 -->
    <TextView
        android:id="@+id/overlay_seek_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:padding="10dp"
        android:textColor="#FFFFFF"
        android:text="@string/video_seek_rewind_10s"
        android:background="#88000000"
        android:elevation="6dp"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/overlay_seek_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:padding="10dp"
        android:textColor="#FFFFFF"
        android:text="@string/video_seek_forward_10s"
        android:background="#88000000"
        android:elevation="6dp"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <!-- 中部双击播放/暂停提示浮层 -->
    <TextView
        android:id="@+id/overlay_play_pause"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="#FFFFFF"
        android:text="@string/video_play_pause"
        android:background="#88000000"
        android:elevation="6dp"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <!-- 左右拖拽进度手势提示浮层 -->
    <LinearLayout
        android:id="@+id/seek_feedback_layout"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="16dp"
        android:background="@drawable/bg_video_overlay"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="6dp"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no">

        <TextView
            android:id="@+id/seek_feedback_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="00:00 / 00:00" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/seek_feedback_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:indeterminate="false"
            app:trackThickness="4dp"
            app:indicatorColor="?attr/colorTertiary"
            app:trackColor="#44FFFFFF"
            app:trackCornerRadius="2dp" />
            
    </LinearLayout>

    <!-- Subtitle text overlay rendered by Android (MPV OSD doesn't work on Android) -->
    <!-- Must be LAST child in FrameLayout to render on top of SurfaceView and all other views -->
    <TextView
        android:id="@+id/subtitle_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:lineSpacingExtra="4dp"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="8"
        android:background="#66000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

    <!-- Screen lock touch-intercepting overlay -->
    <View
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp" />

    <!-- Unlock button shown centered when screen is locked and user taps -->
    <ImageButton
        android:id="@+id/button_screen_unlock"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_video_overlay"
        android:src="@drawable/ic_lock_open"
        android:scaleType="centerInside"
        android:padding="16dp"
        android:tint="@android:color/white"
        android:contentDescription="@string/video_screen_unlock"
        android:visibility="gone"
        android:elevation="12dp" />

</FrameLayout>
