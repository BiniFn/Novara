<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/titleSettings"
        style="@style/TextAppearance.MaterialComponents.Headline6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings" />

    <TextView
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/reader_font_size" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderFontSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="12"
        android:valueTo="24"
        android:stepSize="1" />

    <TextView
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/reader_line_height" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderLineHeight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="1.2"
        android:valueTo="2.4"
        android:stepSize="0.1" />

    <TextView
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/reader_margins" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderMargin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="8"
        android:valueTo="32"
        android:stepSize="1" />

    <TextView
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/reader_mode" />

    <RadioGroup
        android:id="@+id/radioModeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioModeDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reader_mode_default" />

        <RadioButton
            android:id="@+id/radioModeRtl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reader_mode_rtl" />

        <RadioButton
            android:id="@+id/radioModeVertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reader_mode_vertical" />

        <RadioButton
            android:id="@+id/radioModeVerticalContinuous"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reader_mode_vertical_continuous" />
    </RadioGroup>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchDualPage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/reader_dual_page" />

</LinearLayout>
