<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:columnCount="2"
    android:rowCount="2"
    android:paddingEnd="12dp"
    android:layout_gravity="end|center_vertical"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Row 0, Column 0: Manga -->
    <ImageView
        android:id="@+id/filter_content_manga"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_row="0"
        android:layout_column="0"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/manga"
        android:padding="4dp"
        android:src="@drawable/ic_content_manga" />

    <!-- Row 0, Column 1: Novel -->
    <ImageView
        android:id="@+id/filter_content_novel"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_row="0"
        android:layout_column="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/novel"
        android:padding="4dp"
        android:src="@drawable/ic_content_novel" />

    <!-- Row 1, Column 0: Video -->
    <ImageView
        android:id="@+id/filter_content_video"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_row="1"
        android:layout_column="0"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/video"
        android:padding="4dp"
        android:src="@drawable/ic_content_video" />

    <!-- Row 1, Column 1: Source Tag / Tracker Site -->
    <ImageView
        android:id="@+id/filter_source_tag"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_row="1"
        android:layout_column="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/filter"
        android:padding="4dp"
        android:src="@drawable/ic_filter_menu" />

</GridLayout>
