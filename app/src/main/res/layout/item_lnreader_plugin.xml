<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:paddingHorizontal="@dimen/margin_normal"
	android:paddingVertical="@dimen/margin_small">

	<com.google.android.material.imageview.ShapeableImageView
		android:id="@+id/image_view_icon"
		android:layout_width="40dp"
		android:layout_height="40dp"
		android:scaleType="centerCrop"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintBottom_toBottomOf="parent"
		app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Kototoro.Cover.Small"
		tools:src="@drawable/ic_placeholder" />

	<TextView
		android:id="@+id/text_view_name"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/margin_normal"
		android:ellipsize="end"
		android:maxLines="1"
		android:textAppearance="?attr/textAppearanceBodyLarge"
		app:layout_constraintEnd_toStartOf="@id/text_view_version"
		app:layout_constraintStart_toEndOf="@id/image_view_icon"
		app:layout_constraintTop_toTopOf="parent"
		tools:text="Royal Road" />

	<TextView
		android:id="@+id/text_view_site"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="@dimen/margin_normal"
		android:ellipsize="end"
		android:maxLines="1"
		android:textAppearance="?attr/textAppearanceBodySmall"
		android:textColor="?android:attr/textColorSecondary"
		app:layout_constraintEnd_toStartOf="@id/button_install"
		app:layout_constraintStart_toEndOf="@id/image_view_icon"
		app:layout_constraintTop_toBottomOf="@id/text_view_name"
		tools:text="https://www.royalroad.com/" />

	<TextView
		android:id="@+id/text_view_version"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginEnd="@dimen/margin_small"
		android:textAppearance="?attr/textAppearanceLabelSmall"
		android:textColor="?android:attr/textColorSecondary"
		app:layout_constraintEnd_toStartOf="@id/button_install"
		app:layout_constraintTop_toTopOf="parent"
		tools:text="v2.2.3" />

	<com.google.android.material.button.MaterialButton
		android:id="@+id/button_install"
		android:layout_width="wrap_content"
		android:layout_height="36dp"
		android:minWidth="80dp"
		android:textSize="12sp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		style="@style/Widget.Material3.Button.TonalButton"
		tools:text="@string/_install" />

</androidx.constraintlayout.widget.ConstraintLayout>
