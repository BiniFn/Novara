<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
		android:id="@+id/swipeRefreshLayout"
		android:layout_width="match_parent"
		android:layout_height="match_parent">

		<androidx.core.widget.NestedScrollView
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:clipToPadding="false">

			<LinearLayout
				android:id="@+id/contentGroup"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:padding="@dimen/list_spacing_normal"
				android:visibility="gone"
				tools:visibility="visible">

				<org.skepsun.kototoro.image.ui.CoverImageView
					android:id="@+id/imageViewCover"
					android:layout_width="160dp"
					android:layout_height="240dp"
					android:layout_gravity="center_horizontal"
					android:contentDescription="@null"
					android:scaleType="centerCrop"
					tools:src="@drawable/ic_bangumi_outline" />

				<TextView
					android:id="@+id/textViewTitle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="16dp"
					android:gravity="center"
					android:textAppearance="?attr/textAppearanceHeadlineSmall"
					tools:text="Title" />

				<TextView
					android:id="@+id/textViewAltTitle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:gravity="center"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textColor="?android:textColorSecondary"
					tools:text="Alternative title" />

				<TextView
					android:id="@+id/textViewSite"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:gravity="center"
					android:textAppearance="?attr/textAppearanceTitleSmall"
					tools:text="Bangumi" />

				<TextView
					android:id="@+id/textViewScore"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:gravity="center"
					android:textAppearance="?attr/textAppearanceBodyLarge"
					tools:text="8.5" />

				<TextView
					android:id="@+id/textViewRank"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:gravity="center"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textColor="?android:textColorSecondary"
					tools:text="Rank #123" />

				<TextView
					android:id="@+id/textViewBindingStatus"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:gravity="center"
					android:textAppearance="?attr/textAppearanceBodyMedium"
					android:textColor="?android:textColorSecondary"
					tools:text="Linked to local content" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="16dp"
					android:orientation="vertical">

					<LinearLayout
						android:id="@+id/layoutYear"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical"
						android:paddingVertical="4dp">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/year"
							android:textAppearance="?attr/textAppearanceTitleSmall" />

						<TextView
							android:id="@+id/textViewYear"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							tools:text="2024" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/layoutEpisodes"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical"
						android:paddingVertical="4dp">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/discover_total_episodes"
							android:textAppearance="?attr/textAppearanceTitleSmall" />

						<TextView
							android:id="@+id/textViewEpisodes"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							tools:text="12" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/layoutAuthors"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical"
						android:paddingVertical="4dp">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/authors"
							android:textAppearance="?attr/textAppearanceTitleSmall" />

						<TextView
							android:id="@+id/textViewAuthors"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							tools:text="Author A, Author B" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/layoutTags"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical"
						android:paddingVertical="4dp">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/discover_tags"
							android:textAppearance="?attr/textAppearanceTitleSmall" />

						<TextView
							android:id="@+id/textViewTags"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							tools:text="Drama, Action" />
					</LinearLayout>

					<LinearLayout
						android:id="@+id/layoutDescription"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical"
						android:paddingVertical="4dp">

						<TextView
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="@string/description"
							android:textAppearance="?attr/textAppearanceTitleSmall" />

						<TextView
							android:id="@+id/textViewDescription"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="4dp"
							android:textAppearance="?attr/textAppearanceBodyMedium"
							tools:text="Description" />
					</LinearLayout>
				</LinearLayout>

				<LinearLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="center_horizontal"
					android:layout_marginTop="16dp"
					android:gravity="center"
					android:orientation="horizontal">

					<com.google.android.material.button.MaterialButton
						android:id="@+id/buttonOpenLocal"
						style="?attr/materialButtonOutlinedStyle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginEnd="8dp"
						android:text="@string/discover_open_local" />

					<com.google.android.material.button.MaterialButton
						android:id="@+id/buttonOpenSite"
						style="?attr/materialButtonOutlinedStyle"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/discover_open_site" />
				</LinearLayout>

				<com.google.android.material.button.MaterialButton
					android:id="@+id/buttonManageBinding"
					style="?attr/materialButtonOutlinedStyle"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="center_horizontal"
					android:layout_marginTop="12dp"
					android:text="@string/discover_bind_local" />

			</LinearLayout>
		</androidx.core.widget.NestedScrollView>
	</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

	<LinearLayout
		android:id="@+id/errorGroup"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:gravity="center"
		android:orientation="vertical"
		android:padding="@dimen/list_spacing_normal"
		android:visibility="gone">

		<ImageView
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:contentDescription="@null"
			android:src="@drawable/ic_error_large" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/error_occurred"
			android:textAppearance="?attr/textAppearanceTitleMedium" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/buttonRetry"
			style="?attr/materialButtonOutlinedStyle"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/retry" />
	</LinearLayout>

	<com.google.android.material.progressindicator.CircularProgressIndicator
		android:id="@+id/progressBar"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_gravity="center"
		android:visibility="gone" />

</FrameLayout>
