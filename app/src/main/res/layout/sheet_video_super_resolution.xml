<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <org.skepsun.kototoro.core.ui.sheet.AdaptiveSheetHeaderBar
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/video_super_resolution" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:scrollIndicators="top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/margin_normal">

            <com.google.android.material.card.MaterialCardView
                style="?materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_normal"
                android:layout_marginEnd="@dimen/margin_normal"
                android:layout_marginTop="@dimen/margin_normal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/margin_normal"
                    android:paddingEnd="@dimen/margin_normal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_off"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_off" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_quality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_quality" />

                    <org.skepsun.kototoro.core.ui.widgets.ListItemTextView
                        android:id="@+id/button_quality_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_submode"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_settings"
                        tools:visibility="visible" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_balanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_balanced" />

                    <org.skepsun.kototoro.core.ui.widgets.ListItemTextView
                        android:id="@+id/button_balanced_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_submode"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_settings"
                        tools:visibility="visible" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_performance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_performance" />

                    <org.skepsun.kototoro.core.ui.widgets.ListItemTextView
                        android:id="@+id/button_performance_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_submode"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_settings"
                        tools:visibility="visible" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_advanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/video_super_resolution_advanced" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <org.skepsun.kototoro.core.ui.widgets.ListItemTextView
                android:id="@+id/button_advanced_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_normal"
                android:layout_marginEnd="@dimen/margin_normal"
                android:layout_marginTop="8dp"
                android:text="@string/video_super_resolution_advanced_settings"
                android:visibility="gone"
                app:drawableStartCompat="@drawable/ic_settings"
                tools:visibility="visible" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</LinearLayout>
