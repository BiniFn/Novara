<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/root_layout"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?attr/colorSurface"
	tools:context=".details.ui.DetailsActivity">

	<androidx.constraintlayout.widget.ConstraintLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="?attr/colorSurface">

		<ImageView
			android:id="@+id/imageView_transition_background"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:contentDescription="@null"
			android:scaleType="centerCrop"
			android:visibility="gone"
			tools:background="@tools:sample/backgrounds/scenic[7]" />

		<androidx.compose.ui.platform.ComposeView
			android:id="@+id/compose_view"
			android:layout_width="match_parent"
			android:layout_height="match_parent" />

		<org.skepsun.kototoro.image.ui.CoverImageView
			android:id="@+id/imageView_cover"
			android:layout_width="0dp"
			android:layout_height="0dp"
			android:background="?colorSecondaryContainer"
			android:clipToOutline="true"
			android:scaleType="centerCrop"
			app:allowRgb565="false"
			app:useExistingDrawable="true"
			tools:background="@tools:sample/backgrounds/scenic[5]"
			tools:ignore="ContentDescription,UnusedAttribute" />

	</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
