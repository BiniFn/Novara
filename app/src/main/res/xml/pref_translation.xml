<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:title="@string/translation_settings">

    <PreferenceCategory
        android:key="translation_section_general"
        android:title="@string/reader_translation_section_general">

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="reader_translation_debug_logs"
            android:summary="@string/reader_translation_debug_logs_summary"
            android:title="@string/reader_translation_debug_logs" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="reader_translation_quality_filter_enabled"
            android:summary="@string/reader_translation_quality_filter_enabled_summary"
            android:title="@string/reader_translation_quality_filter_enabled" />

        <ListPreference
            android:defaultValue="LOCAL_FIRST"
            android:entries="@array/reader_translation_modes"
            android:entryValues="@array/values_reader_translation_modes"
            android:key="reader_translation_mode"
            android:title="@string/reader_translation_mode"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="TWO_STAGE"
            android:entries="@array/reader_translation_pipeline_modes"
            android:entryValues="@array/values_reader_translation_pipeline_modes"
            android:key="reader_translation_pipeline_mode"
            android:title="@string/reader_translation_pipeline_mode"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="auto"
            android:entries="@array/reader_translation_source_languages"
            android:entryValues="@array/values_reader_translation_source_languages"
            android:key="reader_translation_source_lang"
            android:summary="@string/reader_translation_source_lang_summary"
            android:title="@string/reader_translation_source_lang"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:defaultValue="zh"
            android:entries="@array/reader_translation_target_languages"
            android:entryValues="@array/values_reader_translation_target_languages"
            android:key="reader_translation_target_lang"
            android:title="@string/reader_translation_target_lang"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="reader_translation_onnx_model_id"
            android:title="@string/reader_translation_onnx_model_selection" />

        <PreferenceScreen
            android:key="reader_translation_open_api_settings"
            android:fragment="org.skepsun.kototoro.settings.TranslationApiSettingsFragment"
            android:summary="@string/reader_translation_open_api_settings_summary"
            android:title="@string/reader_translation_open_api_settings" />

        <PreferenceScreen
            android:key="reader_e2e_open_api_settings"
            android:fragment="org.skepsun.kototoro.settings.TranslationEndToEndApiSettingsFragment"
            android:summary="Configure API keys and Endpoint for End-to-End Multimodal OCR"
            android:title="End-to-End API Settings" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="translation_section_ocr"
        android:title="@string/reader_translation_section_ocr">

        <Preference
            android:key="reader_translation_manage_ocr_models"
            android:title="@string/reader_translation_manage_ocr_models"
            android:summary="@string/reader_translation_manage_ocr_models_summary"
            android:fragment="org.skepsun.kototoro.settings.OcrModelsFragment" />

        <!-- Note: This legacy key 'reader_translation_paddle_det_model_id' now maps to the global OCR Detector Selection -->
        <ListPreference
            android:key="reader_translation_paddle_det_model_id"
            android:title="@string/reader_translation_ocr_det_model_selection"
            android:summary="@string/reader_translation_ocr_det_model_selection_summary" />

        <!-- Note: This legacy key 'reader_translation_paddle_official_model_id' now maps to the global OCR Recognizer Selection -->
        <ListPreference
            android:key="reader_translation_paddle_official_model_id"
            android:title="@string/reader_translation_ocr_recognizer_model_selection" />

        <ListPreference
            android:defaultValue="HYBRID"
            android:entries="@array/reader_translation_ocr_pipeline_strategies"
            android:entryValues="@array/values_reader_translation_ocr_pipeline_strategies"
            android:key="reader_translation_ocr_pipeline_strategy"
            android:title="@string/reader_translation_ocr_pipeline_strategy"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="translation_section_bubble"
        android:title="@string/reader_translation_section_bubble">

        <ListPreference
            android:key="reader_translation_bubble_detector_model_id"
            android:title="@string/reader_translation_onnx_bubble_model_selection"
            android:summary="@string/reader_translation_onnx_bubble_model_selection_summary" />

        <androidx.preference.SeekBarPreference
            android:defaultValue="85"
            android:key="reader_translation_bubble_detector_nms_dummy"
            android:max="100"
            android:title="@string/reader_translation_bubble_detector_nms"
            android:summary="@string/reader_translation_bubble_detector_nms_summary"
            app:showSeekBarValue="true"
            app:updatesContinuously="true" />

        <ListPreference
            android:defaultValue="BALANCED"
            android:entries="@array/reader_translation_tuning_levels"
            android:entryValues="@array/values_reader_translation_tuning_levels"
            android:key="reader_translation_bubble_grouping_tuning"
            android:summary="@string/reader_translation_bubble_grouping_tuning_summary"
            android:title="@string/reader_translation_bubble_grouping_tuning"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="reader_translation_bubble_detector_enabled"
            android:summary="@string/reader_translation_bubble_detector_enabled_summary"
            android:title="@string/reader_translation_bubble_detector_enabled" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="reader_translation_bubble_grouping_enabled"
            android:summary="@string/reader_translation_bubble_grouping_enabled_summary"
            android:title="@string/reader_translation_bubble_grouping_enabled" />

        <ListPreference
            android:defaultValue="BALANCED"
            android:entries="@array/reader_translation_tuning_levels"
            android:entryValues="@array/values_reader_translation_tuning_levels"
            android:key="reader_translation_overlay_compactness"
            android:summary="@string/reader_translation_overlay_compactness_summary"
            android:title="@string/reader_translation_overlay_compactness"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

</PreferenceScreen>
