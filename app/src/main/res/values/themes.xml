		<item name="android:popupBackground">@drawable/bg_popup_24</item>
	</style>


	<!-- App Widgets -->

	<style name="Theme.Novara.AppWidgetContainer" parent="@style/Theme.MaterialComponents.Light">
		<item name="android:colorBackground">@color/novara_background</item>
		<item name="android:panelColorBackground">@color/novara_primaryContainer</item>
	</style>
</resources>
